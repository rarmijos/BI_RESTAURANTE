    <connection>POSTGRES_DW</connection>
    <sql>SELECT 
    e.id_entrega AS id_entrega_original,
    de.id_detalle AS id_detalle_original,
    e.fecha_pedido,
    e.fecha_entrega_programada,
    e.fecha_entrega_real,
    e.id_proveedor,
    e.id_sucursal,
    e.tipo_entrega,
    e.prioridad,
    de.id_insumo,
    de.cantidad_solicitada,
    de.cantidad_recibida,
    de.precio_unitario,
    de.subtotal,
    de.estado_calidad,
    cr.tiempo_transporte,
    cr.minutos_retraso,
    cr.distancia_recorrida,
    cr.cumple_plazo,
    cr.temperatura_producto,
    cr.temperatura_esperada,
    cr.cumple_refrigeracion,
    cr.calificacion_control,
    i.id_tipo
FROM staging.mysql_entregas e
JOIN staging.mysql_detalle_entregas de ON e.id_entrega = de.id_entrega
JOIN staging.mysql_control_recepcion cr ON e.id_entrega = cr.id_entrega
JOIN staging.mysql_insumos i ON de.id_insumo = i.id_insumo;</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
